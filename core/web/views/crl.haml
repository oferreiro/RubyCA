%h2 CRL
.row
  %legend Current CRL
  %table.table.table-striped.table-hover.table-sm
    %thead
      %tr
        %th Issuer Common Name
        %th Last Update (UTC)
        %th Next Update (UTC)
        %th
    %tbody
      - @crl_infos.each do |crl_info|
        %tr
          %td
            = crl_info[:issuer]['CN']
          %td
            = crl_info[:last_update].strftime('%d/%m/%y %H:%M:%S')
          %td
            = crl_info[:next_update].strftime('%d/%m/%y %H:%M:%S')  
          %td
            .btn-group.float-end
              %a.btn.btn-sm.btn-info{ href: "/admin/crl/#{crl_info[:id]}/info", 'data-bs-get'=>'modal',  'data-bs-title' => 'CRL Info'}
                %i.fas.fa-info-circle
                %span.d-none.d-md-inline Info
              %a.btn.btn-sm.btn-primary{ href: "/ca-#{crl_info[:id]}.crl"}
                %i.fas.fa-download
                %span.d-none.d-md-inline Download 
              - if crl_info[:expired] || crl_info[:to_expire]
                %a.btn.btn-sm.btn-warning{ :href => '/admin/crl/renew'}
                  %i.fas.fa-sync
                  %span.d-none.d-md-inline Renew
.row
  %legend Config
  .col-md-6.col-xs-12.pull-left
    %form#cfg_crl_add_uri{ action: '/admin/crl/config', method: 'post' }
      .mb-3
        .input-group
          %input{type: 'hidden', value: '1', name: 'ca[crl][dist][add_uri]'} 
          %input.form-control#add_uri{ name: 'ca[crl][dist][uri_prefix]', type: 'text', placeholder: 'CRL Distribution Point url', |
            'title' => 'e.g. http://domain.com/ca/ca.crl http://ca.domain.com/ca.crl', 'data-bs-toggle' => 'tooltip'}
          
          %span.input-group-btn
            %button.btn.btn-primary{ type: 'submit' } Add
            
    %form#cfg_crl_rm_uri{ action: '/admin/crl/config', method: 'post' }        
      .mb-3
        %input{type: 'hidden', value: '1', name: 'ca[crl][dist][rm_uri]'} 
        %select.form-control#rm_uri{ multiple: 'true', name: 'ca[crl][dist][uri_prefix][]' }
          - if !@crl_dist.nil?
            -@crl_dist.each do |uri|
              %option{ value: "#{uri}" } #{uri}
      %button.btn.btn-primary{ type: 'submit' } Remove Selected